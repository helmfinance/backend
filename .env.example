# --- Chain ---
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
MANTLE_RPC=https://rpc.mantle.xyz
CHAIN_ID=5003

# --- Cron signer (for harvest, distribute, advance phase, rebalance) ---
# Distinct from deployer key. Has limited on-chain authority.
CRON_SIGNER_PRIVATE_KEY=0x...

# --- Anthropic (Claude Sonnet 4.6) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (current LLM provider for mandate parser + narrator) ---
OPENAI_API_KEY=sk-...
OPENAI_MANDATE_MODEL=gpt-4o-mini
OPENAI_NARRATOR_MODEL=gpt-4o

# --- Indexer (cycle cadence + RPC batch size) ---
INDEXER_POLL_SECONDS=15
INDEXER_CHUNK_BLOCKS=200

# --- Database (SQLite for hackathon, swap to Postgres for prod) ---
DATABASE_URL=sqlite:///./helm.db
# Railway with a /data volume mount (persistent across deploys):
# DATABASE_URL=sqlite:////data/helm.db
# DATABASE_URL=postgresql+psycopg://helm:helm@localhost/helm

# --- IPFS pinning (web3.storage / Pinata / NFT.storage) ---
IPFS_PIN_PROVIDER=web3storage
WEB3_STORAGE_TOKEN=

# --- Pyth (Hermes API + Mantle Pyth contract) ---
PYTH_HERMES_URL=https://hermes.pyth.network
PYTH_CONTRACT=0x98046Bd286715D3B0BC227Dd7a956b83D8978603

# Verified Stable feed IDs from pyth-verify (Step 1)
PYTH_FEED_NVDA=0xb1073854ed24cbc755dc527418f52b7d271f6cc967bbf8d8129112b18860a593
PYTH_FEED_SPY=0x19e09bb805456ada3979a7d1cbb4b6d63babc3a0f8e8a9509f68afa5c4c11cd5
PYTH_FEED_AAPL=0x49f6b65cb1de6b10eaf75e7c03ca029c306d0357e91b5311b175084a5ad55688
PYTH_FEED_TSLA=0x16dad506d7db8da01c87581c87ca897a012a153557d4d578c3b9c9e1bc0632f1
PYTH_FEED_MSFT=0xd0ca23c1cc005e004ccf1db5bf76aeb6a49218f43dac3d4b275e92de12ded4d1
PYTH_FEED_ETH_USD=0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace
PYTH_FEED_USDC_USD=0xeaa020c61cc479712813461ce153894a96a6c00b21ed0cfc2798d1f9a9e9c94a

# --- Deployed contract addresses (filled by forge script after deploy) ---
HELM_REGISTRY=0x...
PLATFORM_TREASURY=0x...
REDEMPTION_QUEUE=0x...
YIELD_HARVESTER=0x...
DIVIDEND_DISTRIBUTOR=0x...
PYTH_PRICE_ADAPTER=0x...
MANTLE_METH_ADAPTER=0x...
ONDO_USDY_ADAPTER=0x...

# AgentNFT (ERC-8004) — reputation + tokenURI
AGENT_NFT=0x...

# TimeProvider — demo time acceleration (testnet only)
TIME_PROVIDER=0x...

# EIP-1167 minimal proxy implementations (clone originals)
AGENT_TOKEN_IMPL=0x...
AGENT_VAULT_IMPL=0x...
FOUNDER_VAULT_IMPL=0x...

# --- Token addresses on Mantle Sepolia ---
USDC=0x...
MANTLE_METH=
ONDO_USDY=

# --- Synthetic equity assets (Pyth-priced, USDC-collateralized) ---
SNVDA=0x...
SSPY=0x...
SAAPL=0x...
STSLA=0x...
SMSFT=0x...

# --- Server ---
LOG_LEVEL=INFO
# Comma-separated allow-list. Empty → ["*"] (dev). Production example:
# CORS_ORIGINS=http://localhost:3000,https://helm-fe.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Railway injects PORT at runtime; entrypoint.sh respects it. Set locally if
# you want to override the 8000 default:
# PORT=8000
